generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  STUDENT
  TEACHER
}

enum ActivityType {
  EXTENSION
  COURSE
  EVENT
  LECTURE
  OTHER
}

enum ActivityFormat {
  IN_PERSON
  ONLINE
  HYBRID
}

enum ActivityStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CampusLocation {
  MACEIO         
  ARAPIRACA      
  PALMEIRA       
  PENEDO         
  RIO_LARGO      
  DELMIRO_GOUVEIA
  SANTANA_IPANEMA
}


model User {
  id           String   @id @default(uuid())
  fullName     String
  email        String   @unique
  passwordHash String
  userType     UserType
  isManager    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student     Student?
  teacher     Teacher?
  activities  Activity[]
  enrollments Enrollment[]
}

model Student {
  userId           String   @id
  registrationCode String   @unique
  course           String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Teacher {
  userId           String   @id
  registrationCode String   @unique
  cndb             String   @unique
  course           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Address {
  id          String   @id @default(uuid())
  addressLine String
  district    String
  zipCode     String
  city        String
  state       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  activities ActivityDetails[]
}

model Activity {
  id        String          @id @default(uuid())
  authorId  String
  title     String
  type      ActivityType
  campus    CampusLocation
  startDate DateTime
  endDate   DateTime
  slots     Int             @default(1)
  status    ActivityStatus  @default(OPEN)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([status])
  @@index([type])
  @@index([authorId])
  @@index([startDate, endDate])

  author      User             @relation(fields: [authorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  details     ActivityDetails?
  enrollments Enrollment[]
}

model ActivityDetails {
  activityId  String         @id
  description String
  area        String
  format      ActivityFormat
  url         String?
  workloadHours    Int
  addressId   String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("activity_details")

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  address  Address? @relation(fields: [addressId], references: [id], onDelete: SetNull, onUpdate: Cascade)
}

model Enrollment {
  id                  String           @id @default(uuid())
  userId              String
  activityId          String
  status              EnrollmentStatus
  attendanceConfirmed Boolean          @default(false)
  isModerator         Boolean          @default(false)
  enrolledAt          DateTime         @default(now())
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([userId])
  @@index([activityId])

  user        User         @relation(fields: [userId], references: [id], onUpdate: Cascade)
  activity    Activity     @relation(fields: [activityId], references: [id], onUpdate: Cascade)
  certificate Certificate?

  @@unique([userId, activityId])
}

model Certificate {
  id             String   @id @default(uuid())
  enrollmentId   String   @unique
  validationCode String   @unique
  fileUrl        String
  issuedAt       DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onUpdate: Cascade)
}
